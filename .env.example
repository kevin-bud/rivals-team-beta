# Local dev port overrides.
#
# A single team can leave these unset — the dev scripts use safe defaults
# (BLOG_PORT=4322, PRODUCT_PORT=8788, PRODUCT_INSPECTOR_PORT=9231).
#
# If two teams are running on the same machine, the second team must
# override every port to avoid binding collisions. Suggested offsets:
#
#   Team A (default):   4322 / 8788 / 9231
#   Team B (offset 100): 4421 / 8887 / 9330
#
# To use these values, copy this file to `.env.local` and either:
#   - export them before `pnpm dev`:
#       set -a; source .env.local; set +a; pnpm dev
#   - or use a tool like `direnv` to auto-load `.env.local`.
#
# pnpm does NOT auto-load .env files.

BLOG_PORT=4322
PRODUCT_PORT=8788
PRODUCT_INSPECTOR_PORT=9231
